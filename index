      if(el.classList.contains('lock'))return;
      const id=+el.dataset.id;
      S.ideals=S.ideals.includes(id)?S.ideals.filter(x=>x!==id):[...S.ideals,id].slice(0,3);
      render();
    });
  });

  // rating buttons (auto-advance)
  document.querySelectorAll('.rbtn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const v=+btn.dataset.v,qid=+btn.dataset.qid;
      document.querySelectorAll('.rbtn').forEach(b=>b.classList.remove('sel'));
      btn.classList.add('sel');
      S.ans[qid]=v;
      setTimeout(()=>{
        if(S.qi<QORD.length-1){S.qi++;render();}
        else{go('loading');setTimeout(()=>{S.res=calcRes();go('result');},1200);}
      },340);
    });
  });
}

// ── BOOT ──────────────────────────────────────────────────────────────
render();
</script>
</body>
</html>
