// ── RADAR CHART (Canvas API 自前実装) ─────────────────────────────────
function drawChart(){
  const cv=document.getElementById('rc');
  if(!cv)return;
  const ctx=cv.getContext('2d');
  const W=cv.width,H=cv.height,cx=W/2,cy=H/2;
  const R=W*0.33,LR=W*0.44;
  const labels=Object.values(AXNAMES);
  const vals=Object.values(S.res.ax).map(v=>v/16);
  const N=labels.length;
  const ang=i=>(i/N)*Math.PI*2-Math.PI/2;
  const pt=(r,i)=>({x:cx+r*Math.cos(ang(i)),y:cy+r*Math.sin(ang(i))});

  ctx.clearRect(0,0,W,H);

  // grid circles
  [.25,.5,.75,1].forEach(lv=>{
    ctx.beginPath();
    for(let i=0;i<N;i++){const p=pt(R*lv,i);i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y);}
    ctx.closePath();
    ctx.strokeStyle='rgba(0,0,0,0.09)';ctx.lineWidth=1;ctx.stroke();
    if(lv===1){ctx.fillStyle='rgba(240,242,255,0.5)';ctx.fill();}
  });

  // axis lines
  for(let i=0;i<N;i++){
    const p=pt(R,i);
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(p.x,p.y);
    ctx.strokeStyle='rgba(0,0,0,0.09)';ctx.lineWidth=1;ctx.stroke();
  }

  // data polygon
  ctx.beginPath();
  for(let i=0;i<N;i++){const p=pt(R*vals[i],i);i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y);}
  ctx.closePath();
  ctx.fillStyle='rgba(91,127,255,0.22)';ctx.fill();
  ctx.strokeStyle='rgba(91,127,255,0.9)';ctx.lineWidth=2.5;ctx.stroke();

  // dots
  for(let i=0;i<N;i++){
    const p=pt(R*vals[i],i);
    ctx.beginPath();ctx.arc(p.x,p.y,4.5,0,Math.PI*2);
    ctx.fillStyle='#5B7FFF';ctx.fill();
    ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();
  }

  // labels
  ctx.fillStyle='#333';ctx.textAlign='center';ctx.textBaseline='middle';
  const fs=Math.round(W*0.037);
  ctx.font=`600 ${fs}px -apple-system,sans-serif`;
  for(let i=0;i<N;i++){
    const p=pt(LR,i);
    const lbl=labels[i];
    // wrap long labels
    if(lbl.length>6){
      ctx.font=`600 ${fs-1}px -apple-system,sans-serif`;
      ctx.fillText(lbl.slice(0,4),p.x,p.y-7);
      ctx.fillText(lbl.slice(4),p.x,p.y+7);
      ctx.font=`600 ${fs}px -apple-system,sans-serif`;
    } else {
      ctx.fillText(lbl,p.x,p.y);
    }
  }
}

