<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>学級経営力診断テスト</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --p:#5B7FFF;--pd:#3D5FE0;--pl:#EEF1FF;
  --ac:#FF8C42;--ok:#4CAF81;
  --tx:#1A1A2E;--ts:#6B7280;
  --bg:#F5F7FF;--cd:#fff;--br:#E8ECF4;
  --gr:linear-gradient(135deg,#5B7FFF 0%,#8B5CF6 100%);
}
body{font-family:-apple-system,BlinkMacSystemFont,'Hiragino Sans','Hiragino Kaku Gothic ProN','Yu Gothic UI','Meiryo',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;overflow-x:hidden;}
#app{max-width:480px;margin:0 auto;min-height:100vh;}
.screen{display:none;flex-direction:column;min-height:100vh;animation:fadeUp .3s ease both;}
.screen.active{display:flex;}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
@keyframes pop{0%{transform:scale(1);}60%{transform:scale(1.15);}100%{transform:scale(1.1);}}
@keyframes spin{to{transform:rotate(360deg);}}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.4;}}

/* TOP BAR */
.topbar{position:fixed;top:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;height:5px;background:var(--br);z-index:999;}
.topbar-fill{height:100%;background:linear-gradient(90deg,var(--p),var(--ac));transition:width .4s ease;border-radius:0 3px 3px 0;}

/* INTRO */
.hero{background:var(--gr);padding:64px 24px 48px;color:#fff;text-align:center;}
.badge{display:inline-block;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.3);border-radius:20px;padding:5px 16px;font-size:11px;font-weight:700;letter-spacing:1px;margin-bottom:18px;}
.hero h1{font-size:30px;font-weight:900;line-height:1.35;margin-bottom:14px;}
.hero p{font-size:13px;opacity:.88;line-height:1.7;}
.ibody{padding:20px;}
.stats{display:flex;gap:10px;margin-bottom:18px;}
.scard{flex:1;background:#fff;border-radius:16px;padding:16px 8px;text-align:center;box-shadow:0 2px 12px rgba(0,0,0,.06);}
.snum{font-size:26px;font-weight:900;color:var(--p);}
.slbl{font-size:10px;color:var(--ts);margin-top:3px;}
.fcard{background:#fff;border-radius:20px;padding:20px;margin-bottom:18px;box-shadow:0 2px 12px rgba(0,0,0,.06);}
.fcard h3{font-size:13px;color:var(--ts);font-weight:600;margin-bottom:14px;}
.fitem{display:flex;align-items:flex-start;gap:14px;margin-bottom:14px;}
.fitem:last-child{margin-bottom:0;}
.fnum{width:36px;height:36px;border-radius:50%;background:var(--pl);color:var(--p);font-weight:700;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.finfo h4{font-size:14px;font-weight:700;margin-bottom:2px;}
.finfo p{font-size:12px;color:var(--ts);line-height:1.5;}

/* BUTTONS */
.btn{width:100%;border:none;border-radius:14px;padding:17px;font-size:16px;font-weight:700;font-family:inherit;cursor:pointer;transition:transform .15s,opacity .15s;}
.btn:active{transform:scale(.97);}
.btn-p{background:var(--gr);color:#fff;box-shadow:0 6px 20px rgba(91,127,255,.35);}
.btn-p:disabled{opacity:.4;cursor:not-allowed;transform:none;}
.btn-g{background:var(--pl);color:var(--p);}

/* STEP1 */
.s1hero{background:var(--gr);padding:56px 24px 32px;color:#fff;}
.slabel{font-size:11px;font-weight:700;opacity:.75;letter-spacing:1.5px;margin-bottom:8px;}
.s1hero h2{font-size:22px;font-weight:900;line-height:1.4;margin-bottom:8px;}
.s1hero p{font-size:13px;opacity:.85;line-height:1.6;}
.ilist{padding:14px 14px 0;}
.iitem{display:flex;align-items:center;gap:12px;padding:14px 14px;background:#fff;border-radius:14px;margin-bottom:10px;border:2.5px solid transparent;cursor:pointer;transition:all .18s;box-shadow:0 2px 8px rgba(0,0,0,.05);}
.iitem.on{border-color:var(--p);background:var(--pl);}
.iitem.lock:not(.on){opacity:.35;cursor:not-allowed;}
.ichk{width:24px;height:24px;border-radius:50%;border:2px solid var(--br);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;color:transparent;transition:all .18s;}
.iitem.on .ichk{background:var(--p);border-color:var(--p);color:#fff;}
.iemoji{font-size:20px;flex-shrink:0;}
.itext{font-size:13px;font-weight:500;line-height:1.5;}
.s1foot{position:sticky;bottom:0;background:#fff;padding:12px 14px 20px;border-top:1px solid var(--br);box-shadow:0 -4px 20px rgba(0,0,0,.07);}
.dots{display:flex;justify-content:center;gap:8px;margin-bottom:10px;}
.dot{width:10px;height:10px;border-radius:50%;background:var(--br);transition:background .2s;}
.dot.on{background:var(--p);}
.scnt{text-align:center;font-size:13px;color:var(--ts);margin-bottom:10px;}
.scnt span{color:var(--p);font-weight:700;}

/* STEP2 */
.qhead{background:#fff;padding:52px 18px 16px;border-bottom:1px solid var(--br);}
.qmeta{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.backbtn{background:none;border:none;color:var(--ts);font-size:13px;font-family:inherit;cursor:pointer;padding:4px 0;}
.qslbl{font-size:11px;color:var(--p);font-weight:700;letter-spacing:.5px;}
.qnum{font-size:12px;color:var(--ts);}
.qpbar{height:6px;background:var(--br);border-radius:3px;overflow:hidden;}
.qpfill{height:100%;background:linear-gradient(90deg,var(--p),var(--ac));border-radius:3px;transition:width .4s ease;}
.qbody{flex:1;padding:28px 20px;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.qtag{display:inline-block;background:var(--pl);color:var(--p);font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;margin-bottom:18px;}
.qtext{font-size:18px;font-weight:700;line-height:1.7;text-align:center;margin-bottom:34px;max-width:340px;}
.rwrap{width:100%;max-width:340px;}
.rends{display:flex;justify-content:space-between;margin-bottom:8px;}
.rend{font-size:10px;color:var(--ts);line-height:1.4;max-width:80px;}
.rend:last-child{text-align:right;}
.rbtns{display:flex;gap:8px;justify-content:center;}
.rbtn{width:54px;height:54px;border-radius:14px;border:2px solid var(--br);background:#fff;font-size:18px;font-weight:700;color:var(--ts);cursor:pointer;transition:all .18s;font-family:inherit;box-shadow:0 2px 8px rgba(0,0,0,.05);}
.rbtn:hover{border-color:var(--p);color:var(--p);}
.rbtn.sel{background:var(--p);border-color:var(--p);color:#fff;animation:pop .22s ease forwards;box-shadow:0 4px 14px rgba(91,127,255,.4);}

/* LOADING */
.ldwrap{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:20px;}
.spinner{width:52px;height:52px;border:5px solid var(--pl);border-top-color:var(--p);border-radius:50%;animation:spin .8s linear infinite;}
.ldwrap p{font-size:15px;color:var(--ts);animation:blink 1.4s ease infinite;}

/* RESULT */
.rhero{background:var(--gr);padding:56px 24px 64px;text-align:center;color:#fff;}
.remoji{font-size:60px;margin-bottom:12px;line-height:1;}
.rsub{font-size:13px;opacity:.8;margin-bottom:8px;}
.rname{font-size:34px;font-weight:900;margin-bottom:6px;}
.rtag{font-size:13px;opacity:.85;margin-bottom:20px;}
.rscwrap{background:rgba(255,255,255,.18);border-radius:20px;padding:14px 24px;display:inline-block;}
.rscnum{font-size:52px;font-weight:900;line-height:1;}
.rsclbl{font-size:13px;opacity:.8;margin-top:2px;}
.rscnote{font-size:11px;opacity:.65;margin-top:10px;line-height:1.7;padding:0 8px;}

.rbody{padding:14px;margin-top:-30px;position:relative;z-index:10;}
.rcard{background:#fff;border-radius:20px;padding:22px;margin-bottom:14px;box-shadow:0 4px 20px rgba(0,0,0,.08);}
.rcard h3{font-size:15px;font-weight:700;margin-bottom:14px;}
.rdesc{font-size:14px;line-height:1.85;color:var(--tx);}
.chartwrap{width:100%;max-width:300px;margin:0 auto;}
.slist{list-style:none;}
.slist li{font-size:13px;padding:9px 0;border-bottom:1px solid var(--br);display:flex;align-items:flex-start;gap:9px;line-height:1.55;}
.slist li:last-child{border-bottom:none;}
.slist li::before{content:'✓';color:var(--ok);font-weight:700;flex-shrink:0;margin-top:1px;}
.cideal{font-size:13px;padding:8px 0;border-bottom:1px solid var(--br);display:flex;align-items:flex-start;gap:8px;line-height:1.5;}
.cideal:last-child{border-bottom:none;}
.gapbox{background:var(--pl);border-left:4px solid var(--p);border-radius:0 12px 12px 0;padding:14px 16px;font-size:13px;line-height:1.8;margin-top:10px;}
.gapbox b{color:var(--pd);}
.aitem{background:#F8F9FF;border-radius:14px;padding:16px;margin-bottom:10px;}
.aitem:last-child{margin-bottom:0;}
.anum{width:28px;height:28px;background:var(--p);color:#fff;border-radius:50%;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;margin-bottom:10px;}
.atitle{font-size:14px;font-weight:700;margin-bottom:6px;}
.adesc{font-size:13px;color:var(--ts);line-height:1.65;}

/* SHARE */
.shcard{background:#fff;border-radius:20px;padding:22px;margin-bottom:14px;box-shadow:0 4px 20px rgba(0,0,0,.08);text-align:center;}
.shcard h3{font-size:15px;font-weight:700;margin-bottom:6px;}
.shcard p{font-size:13px;color:var(--ts);margin-bottom:16px;}
.shbtns{display:flex;gap:10px;margin-bottom:8px;}
.shbtn{flex:1;padding:14px;border-radius:12px;border:none;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;transition:transform .15s;text-decoration:none;}
.shbtn:active{transform:scale(.96);}
.shline{background:#06C755;color:#fff;}
.shx{background:#000;color:#fff;}
.shcopy{background:var(--br);color:var(--tx);font-size:13px;width:100%;margin-top:8px;padding:12px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;font-weight:600;}
.copymsg{font-size:12px;color:var(--ok);min-height:18px;margin-top:6px;}
.retrybtn{width:100%;background:var(--pl);color:var(--p);border:none;border-radius:14px;padding:15px;font-size:15px;font-weight:600;cursor:pointer;font-family:inherit;margin-bottom:40px;}
</style>
</head>
